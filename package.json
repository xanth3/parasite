{
  "name": "parasite",
  "version": "0.1.0",
  "description": "Parasite — Windows x64 desktop app for tracking, previewing, uploading, and exporting recorded/downloaded video footage. Connects to Google Drive, controls OBS for stream recording, and does real-time local transcription with Whisper.",
  "main": "main.js",
  "author": "Altar",
  "license": "MIT",
  "homepage": "https://github.com/xanth3/parasite",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanth3/parasite.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "dist": "electron-builder --win --x64 --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "electron-store": "^8.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "googleapis": "^144.0.0",
    "google-auth-library": "^9.14.2",
    "obs-websocket-js": "^5.0.6",
    "chokidar": "^3.6.0",
    "mime-types": "^2.1.35",
    "node-fetch": "^2.7.0",
    "whisper-node": "^1.1.1",
    "twitter-api-v2": "^1.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.altar.parasite",
    "productName": "Parasite",
    "copyright": "Copyright © 2026 Parasite Brands LLC",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/ffmpeg-static/**/*",
      "node_modules/ffprobe-static/**/*",
      "node_modules/whisper-node/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Parasite-Setup-${version}.exe",
      "publisherName": "Parasite Brands LLC"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Parasite",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "menuCategory": false,
      "runAfterFinish": true,
      "differentialPackage": true
    }
  }
}
